# HTTPS reverse proxy for finfam dev services via Tailscale certs.
#
# Caddy auto-provisions TLS certs for *.ts.net domains from the local
# Tailscale daemon — no manual cert generation needed.
#
# Setup (on host, not in agent-env container):
#   1. Install Caddy:  https://caddyserver.com/docs/install
#      - macOS:   brew install caddy
#      - Ubuntu:  sudo apt install -y debian-keyring debian-archive-keyring apt-transport-https \
#                   && curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' | sudo gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg \
#                   && curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' | sudo tee /etc/apt/sources.list.d/caddy-stable.list \
#                   && sudo apt update && sudo apt install caddy
#   2. Enable Tailscale HTTPS: https://tailscale.com/kb/1153/enabling-https
#   3. Allow Caddy to fetch certs (Linux only):
#        echo 'TS_PERMIT_CERT_UID=caddy' | sudo tee -a /etc/default/tailscaled
#        sudo systemctl restart tailscaled
#   4. Start Caddy:
#        sudo caddy start --config /path/to/this/Caddyfile
#
# The file uses the machine's Tailscale hostname. To find yours:
#   tailscale status --self --json | jq -r '.Self.DNSName' | sed 's/\.$//'
# e.g. "slate.boa-cobra.ts.net"
#
# Replace BOTH occurrences of the hostname below, or use the sed one-liner:
#   TSHOST=$(tailscale status --self --json | jq -r '.Self.DNSName' | sed 's/\.$//') \
#     && sed "s/TAILNET_HOST/$TSHOST/g" Caddyfile | sudo caddy start --config -
#
# Port convention: HTTPS port = HTTP port + 300

{
	auto_https disable_redirects
}

# Frontend (SvelteKit/Vite dev server)
https://TAILNET_HOST:5473 {
	reverse_proxy localhost:5173
}

# API (FastAPI/uvicorn)
https://TAILNET_HOST:8381 {
	reverse_proxy localhost:8081
}

# Docs (Astro)
https://TAILNET_HOST:4621 {
	reverse_proxy localhost:4321
}

# MinIO S3 API
https://TAILNET_HOST:9320 {
	reverse_proxy localhost:9020
}

# MinIO Console
https://TAILNET_HOST:9321 {
	reverse_proxy localhost:9021
}

# GoodTurn Frontend (SvelteKit)
https://glob.boa-cobra.ts.net:5483 {
	reverse_proxy localhost:5183
}

# GoodTurn API (FastAPI/uvicorn)
https://glob.boa-cobra.ts.net:8383 {
	reverse_proxy localhost:8083
}
